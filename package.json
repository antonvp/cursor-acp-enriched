{
  "name": "cursor-acp-enriched",
  "version": "0.2.1",
  "description": "Recovers missing tool call arguments from Cursor's ACP events by reading the local SQLite store.db",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cursor",
    "acp",
    "agent-client-protocol",
    "tool-call",
    "sqlite",
    "mcp",
    "enricher"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm run test"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antonvp/cursor-acp-enriched.git"
  },
  "bugs": {
    "url": "https://github.com/antonvp/cursor-acp-enriched/issues"
  },
  "homepage": "https://github.com/antonvp/cursor-acp-enriched#readme"
}
